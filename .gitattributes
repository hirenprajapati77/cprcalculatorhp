# Enforce LF line endings for shell scripts on all platforms
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts use CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Default: auto-detect text files
* text=auto

# Export exclusions for git archive
.env export-ignore
.env.local export-ignore
.env.production export-ignore
ssh_history.jsonl export-ignore
history.txt export-ignore
history_commands.txt export-ignore
clean_ssh_history.txt export-ignore
commands_history.txt export-ignore
raw*.txt export-ignore
*.log export-ignore
*.tar.gz export-ignore
*.zip export-ignore
deploy_bundle* export-ignore
dev.db export-ignore
*.db export-ignore
*.sql export-ignore
scratch/ export-ignore
ops/ export-ignore

