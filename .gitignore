# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
dev.db
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# fyers token
fyers_token.txt

# build artifacts — never commit these
deploy_bundle.tar.gz
deploy_bundle.zip
next-build.tar.gz
next-build.zip
dotnext.tar.gz
standalone.tar.gz
prisma.tar.gz
*.tar.gz
*.zip

# generated remote deploy script (scratch, never commit)
remote_deploy.sh

# local untracked configs / scripts
*.local.env
*.local.sh
