# Security & Rate Limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Market Data Mode: 'live' = Yahoo Finance (real-time) | 'paper' = simulated with fluctuation | 'mock' = static
MARKET_DATA_MODE="live"

# Backtest Execution Mode: 'sync' = process immediately (no Redis needed) | 'queue' = via BullMQ+Redis | 'disabled' = off
BACKTEST_EXECUTION_MODE="sync"

# BTST Window Bypass: 'true' = allow BTST scanning at any time (not just 15:20-15:25 IST)
BTST_BYPASS_WINDOW="false"

HISTORICAL_MODE="live"

