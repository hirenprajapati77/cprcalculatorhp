# -------------------------------------------------------------
# CPR Platform Environment Variables Template
# -------------------------------------------------------------

# Database
# Production URL (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/cpr_db"

# Redis Configuration (Optional, falls back to memory if empty)
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
CACHE_PROVIDER="auto" # 'redis' | 'memory' | 'auto'

# Postgres & Redis Passwords for Docker Compose
POSTGRES_PASSWORD="secure_postgres_password"
REDIS_PASSWORD="secure_redis_password"

# App Configuration
NODE_ENV="development"
APP_BASE_URL="https://your-domain.com"
NEXT_PUBLIC_BASE_URL="https://your-domain.com"
TRUST_PROXY="true"
APP_VERSION="v1.0.0"

# Security & Authentication
CRON_SECRET="your_secure_cron_secret"
APP_ACCESS_TOKEN="your_secure_app_access_token"
TOKEN_ENCRYPTION_KEY="your_secure_encryption_key"

# Rate Limiting
RATE_LIMIT_MAX="60"
RATE_LIMIT_WINDOW_MS="60000"

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"
TELEGRAM_GROUP_CHAT_ID="your_telegram_group_chat_id"

# Fyers API Configuration
FYERS_APP_ID="your_fyers_app_id"
FYERS_SECRET_ID="your_fyers_secret_id"
FYERS_REDIRECT_URL="https://your-domain.com/api/broker/fyers/callback"
FYERS_AUTH_PROXY_URL="https://your-fyers-proxy.example.workers.dev"

# Market & Backtest Modes
MARKET_DATA_MODE="live"
BACKTEST_EXECUTION_MODE="queue"
HISTORICAL_MODE="live"
EXECUTION_MODE="SHADOW"
BTST_BYPASS_WINDOW="false"

# Queues & Scanning
ENABLE_QUEUE="true"
SCAN_QUEUE_THRESHOLD="75"
YAHOO_BATCH_SIZE="10"
YAHOO_MAX_RETRIES="3"
SAVE_IGNORE_SIGNALS="false"
CPR_WEIGHT="35"

# Debug
NEXT_PUBLIC_ENABLE_DEBUG_PANEL="false"
